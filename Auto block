local PlayersFolder, KillersFolder, SurvivorsFolder, IngameFolder

local function isValid(inst)
    return inst and inst:IsDescendantOf(Workspace)
end

local function getPlayersFolder()
    if not isValid(PlayersFolder) then
        PlayersFolder = Workspace:FindFirstChild("Players")
    end
    return PlayersFolder
end

local function getKillersFolder()
    if not isValid(KillersFolder) then
        local pf = getPlayersFolder()
        KillersFolder = pf and pf:FindFirstChild("Killers")
    end
    return KillersFolder
end

local function getSurvivorsFolder()
    if not isValid(SurvivorsFolder) then
        local pf = getPlayersFolder()
        SurvivorsFolder = pf and pf:FindFirstChild("Survivors")
    end
    return SurvivorsFolder
end

local function getIngameFolder()
    if not isValid(IngameFolder) then
        local map = Workspace:FindFirstChild("Map")
        IngameFolder = map and map:FindFirstChild("Ingame")
    end
    return IngameFolder
end

