-- ─── BLOCK LOGIC ────────────────────────────────────────────────────────────

local function doBlock(state)
    pcall(function()
        local network = ReplicatedStorage:FindFirstChild("Modules")
            and ReplicatedStorage.Modules:FindFirstChild("Network")
        if network and network:FindFirstChild("RemoteEvent") then
            network.RemoteEvent:FireServer(state and "Block" or "Unblock")
        else
            game:GetService("VirtualInputManager"):SendKeyEvent(
                state, Enum.KeyCode.F, not state, game
            )
        end
    end)
end

task.spawn(function()
    while true do
        task.wait(0.05)

        if not AUTO_BLOCK_ENABLED then continue end

        -- FIX: safe root check, no CharacterAdded:Wait() stall
        local root = getRoot()
        if not root then continue end

        -- FIX: cooldown check BEFORE scanning enemies
        local now = tick()
        if now - lastBlockTime < BLOCK_COOLDOWN then continue end

        local myPos = root.Position
        local shouldBlock = false

        -- FIX: scan all enemies first, decide, then act
        -- this prevents the loop being frozen mid-scan by task.wait
        for _, enemy in ipairs(Players:GetPlayers()) do
            if shouldBlock then break end
            if enemy == lp or not enemy.Character then continue end

            local theirRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
            if not theirRoot then continue end
            if (theirRoot.Position - myPos).Magnitude > 30 then continue end

            local hum = enemy.Character:FindFirstChildOfClass("Humanoid")
            local animator = hum and hum:FindFirstChildOfClass("Animator")
            if not animator then continue end

            -- FIX: GetPlayingAnimationTracks already filters playing ones,
            -- removed redundant track.IsPlaying check
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                if track.Animation then
                    local animId = track.Animation.AnimationId:match("%d+")
                    if animId and attackAnimIds[animId] then
                        shouldBlock = true
                        break
                    end
                end
            end
        end

        -- FIX: act after scanning, not inside the loop
        if shouldBlock then
            lastBlockTime = tick()
            task.wait(BLOCK_DELAY)
            doBlock(true)
            task.wait(0.07)
            doBlock(false)
        end
    end
end)
