-- ─── DRAGGING ───────────────────────────────────────────────────────────────

local dragging = false
local dragStart, frameStart

topBar.InputBegan:Connect(function(input)
    if guiLocked then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            frameStart.X.Scale, frameStart.X.Offset + delta.X,
            frameStart.Y.Scale, frameStart.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ─── SLIDER ─────────────────────────────────────────────────────────────────

local sliderActive = false
local sliderMoveConn, sliderEndConn

delaySliderFrame.InputBegan:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    sliderActive = true

    sliderMoveConn = UserInputService.InputChanged:Connect(function(moveInput)
        if not sliderActive then return end
        if moveInput.UserInputType == Enum.UserInputType.MouseMovement
            or moveInput.UserInputType == Enum.UserInputType.Touch then
            local relX = math.clamp(
                (moveInput.Position.X - delaySliderFrame.AbsolutePosition.X)
                / delaySliderFrame.AbsoluteSize.X, 0, 1
            )
            delaySlider.Size = UDim2.new(relX, 0, 1, 0)
            BLOCK_DELAY = 0.1 + relX * 0.9
            delayValue.Text = string.format("%.2fs", BLOCK_DELAY)
        end
    end)

    sliderEndConn = UserInputService.InputEnded:Connect(function(endInput)
        if endInput.UserInputType == Enum.UserInputType.MouseButton1 then
            sliderActive = false
            if sliderMoveConn then sliderMoveConn:Disconnect() sliderMoveConn = nil end
            if sliderEndConn then sliderEndConn:Disconnect() sliderEndConn = nil end
        end
    end)
end)

